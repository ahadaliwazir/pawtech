---
interface Props {
  pros: string[];
  cons: string[];
}

const { pros, cons } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-4 my-8">
  <div class="bg-emerald-50 rounded-xl p-5">
    <h4 class="flex items-center gap-2 text-emerald-800 font-semibold mb-3 text-base">
      <span class="w-6 h-6 bg-emerald-500 text-white rounded-full flex items-center justify-center text-xs">+</span>
      Pros
    </h4>
    <ul class="space-y-2 list-none p-0 m-0">
      {pros.map(pro => (
        <li class="flex items-start gap-2 text-sm text-emerald-900">
          <span class="text-emerald-500 mt-0.5 shrink-0">&#10003;</span>
          <span>{pro}</span>
        </li>
      ))}
    </ul>
  </div>

  <div class="bg-red-50 rounded-xl p-5">
    <h4 class="flex items-center gap-2 text-red-800 font-semibold mb-3 text-base">
      <span class="w-6 h-6 bg-red-500 text-white rounded-full flex items-center justify-center text-xs">&minus;</span>
      Cons
    </h4>
    <ul class="space-y-2 list-none p-0 m-0">
      {cons.map(con => (
        <li class="flex items-start gap-2 text-sm text-red-900">
          <span class="text-red-500 mt-0.5 shrink-0">&#10007;</span>
          <span>{con}</span>
        </li>
      ))}
    </ul>
  </div>
</div>
