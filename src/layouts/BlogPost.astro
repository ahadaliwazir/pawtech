---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StarRating from '../components/StarRating.astro';
import AffiliateButton from '../components/AffiliateButton.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, category, rating, price, affiliateLink } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={`${title} | PawTech`} description={description} />
  </head>
  <body class="bg-white text-gray-900 font-sans">
    <Header />
    <main class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
      <article>
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-gray-500 mb-6">
          <a href="/" class="hover:text-gray-900 no-underline">Home</a>
          <span>/</span>
          <a href="/reviews/" class="hover:text-gray-900 no-underline">Reviews</a>
          {category && (
            <>
              <span>/</span>
              <a href={`/categories/${category}/`} class="hover:text-gray-900 no-underline capitalize">
                {category.replace(/-/g, ' ')}
              </a>
            </>
          )}
        </nav>

        <!-- Title -->
        <header class="mb-8">
          {category && (
            <span class="inline-block px-2 py-0.5 text-xs font-medium text-indigo-700 bg-indigo-50 rounded mb-3">
              {category.replace(/-/g, ' ')}
            </span>
          )}
          <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight leading-tight mb-3">{title}</h1>
          <p class="text-lg text-gray-500 mb-4">{description}</p>
          <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500">
            <FormattedDate date={pubDate} />
            {updatedDate && (
              <span class="italic">Updated: <FormattedDate date={updatedDate} /></span>
            )}
          </div>
          {rating && (
            <div class="mt-4">
              <StarRating rating={rating} size="lg" />
            </div>
          )}
        </header>

        <!-- Affiliate CTA (top) -->
        {affiliateLink && (
          <div class="bg-gray-50 rounded-xl p-5 mb-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <div>
              <p class="font-semibold text-gray-900 mb-1">Our Verdict: {rating && rating >= 4 ? 'Highly Recommended' : rating && rating >= 3 ? 'Worth Considering' : 'See Details'}</p>
              <p class="text-sm text-gray-500">Best price we found online</p>
            </div>
            <AffiliateButton href={affiliateLink} price={price} />
          </div>
        )}

        <!-- Article Content -->
        <div class="prose prose-lg prose-gray max-w-none
          [&>h2]:text-2xl [&>h2]:font-bold [&>h2]:mt-10 [&>h2]:mb-4
          [&>h3]:text-xl [&>h3]:font-semibold [&>h3]:mt-8 [&>h3]:mb-3
          [&>p]:text-gray-700 [&>p]:leading-relaxed [&>p]:mb-5
          [&>ul]:space-y-2 [&>ul]:mb-5
          [&>table]:w-full [&>table]:border-collapse [&>table]:my-6
          [&>table>thead>tr>th]:bg-gray-50 [&>table>thead>tr>th]:p-3 [&>table>thead>tr>th]:text-left [&>table>thead>tr>th]:text-sm [&>table>thead>tr>th]:font-semibold
          [&>table>tbody>tr>td]:p-3 [&>table>tbody>tr>td]:border-t [&>table>tbody>tr>td]:border-gray-100 [&>table>tbody>tr>td]:text-sm
        ">
          <slot />
        </div>

        <!-- Affiliate CTA (bottom) -->
        {affiliateLink && (
          <div class="bg-indigo-50 rounded-xl p-6 mt-10 text-center">
            <p class="font-semibold text-gray-900 mb-2">{title}</p>
            {rating && <StarRating rating={rating} />}
            <div class="mt-4">
              <AffiliateButton href={affiliateLink} price={price} />
            </div>
            <p class="text-xs text-gray-500 mt-3">
              Affiliate link — we may earn a commission at no extra cost to you.
            </p>
          </div>
        )}

        <!-- Disclosure -->
        <div class="mt-8 pt-6 border-t border-gray-100">
          <p class="text-xs text-gray-400 leading-relaxed">
            <strong>Affiliate Disclosure:</strong> PawTech earns commissions from qualifying purchases made through links on this site. This doesn't influence our reviews — we recommend products based on honest testing and research. Prices may change. Always check the latest price before purchasing.
          </p>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
