---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featured = posts.slice(0, 3);

const categories = [
  { name: 'GPS Trackers', slug: 'gps-trackers', icon: '📍', desc: 'Keep tabs on your pet anywhere they roam' },
  { name: 'Automatic Feeders', slug: 'feeders', icon: '🍽️', desc: 'Smart feeding on schedule, even when you\'re away' },
  { name: 'Pet Cameras', slug: 'cameras', icon: '📹', desc: 'Watch, talk, and toss treats remotely' },
  { name: 'Smart Litter Boxes', slug: 'litter-boxes', icon: '🚿', desc: 'Self-cleaning boxes that do the dirty work' },
  { name: 'Wearables', slug: 'wearables', icon: '⌚', desc: 'Activity & health tracking for your pet' },
  { name: 'Smart Doors', slug: 'smart-doors', icon: '🚪', desc: 'Microchip-activated pet doors for safety' },
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title={`${SITE_TITLE} — Smart Gadgets for Pet Owners`} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-white text-gray-900 font-sans">
    <Header />

    <!-- Hero -->
    <section class="relative overflow-hidden bg-gradient-to-br from-indigo-50 via-white to-emerald-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
        <div class="max-w-3xl">
          <span class="inline-block px-3 py-1 text-xs font-semibold text-indigo-700 bg-indigo-100 rounded-full mb-4">
            Trusted by 10,000+ pet parents
          </span>
          <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight leading-tight mb-6">
            Smart tech for<br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 to-emerald-500">
              happier pets
            </span>
          </h1>
          <p class="text-lg md:text-xl text-gray-600 mb-8 leading-relaxed max-w-xl">
            In-depth reviews of GPS trackers, automatic feeders, pet cameras, and more. We test every product so you don't have to.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/reviews/" class="inline-flex items-center px-6 py-3 bg-indigo-600 text-white font-semibold rounded-lg hover:bg-indigo-700 transition-colors no-underline text-sm">
              Browse Reviews
              <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a href="/categories/" class="inline-flex items-center px-6 py-3 border border-gray-300 text-gray-700 font-semibold rounded-lg hover:bg-gray-50 transition-colors no-underline text-sm">
              View Categories
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Categories -->
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold mb-3">Shop by Category</h2>
        <p class="text-gray-500">Find the perfect smart gadget for your pet</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
        {categories.map(cat => (
          <a href={`/categories/${cat.slug}/`} class="group p-6 bg-gray-50 rounded-xl hover:bg-white hover:shadow-lg transition-all no-underline border border-transparent hover:border-gray-200">
            <span class="text-3xl block mb-3">{cat.icon}</span>
            <h3 class="font-semibold text-gray-900 group-hover:text-indigo-600 transition-colors text-base mb-1">{cat.name}</h3>
            <p class="text-sm text-gray-500">{cat.desc}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Latest Reviews -->
    <section class="bg-gray-50 py-16">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-10">
          <div>
            <h2 class="text-3xl font-bold mb-1">Latest Reviews</h2>
            <p class="text-gray-500">Our newest in-depth product reviews</p>
          </div>
          <a href="/reviews/" class="text-indigo-600 hover:text-indigo-700 font-medium text-sm no-underline hidden sm:block">
            View all &rarr;
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {featured.map(post => (
            <a href={`/reviews/${post.id}/`} class="group bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all no-underline border border-gray-100">
              <div class="p-6">
                {post.data.category && (
                  <span class="inline-block px-2 py-0.5 text-xs font-medium text-indigo-700 bg-indigo-50 rounded mb-3">
                    {post.data.category.replace('-', ' ')}
                  </span>
                )}
                <h3 class="font-semibold text-gray-900 group-hover:text-indigo-600 transition-colors mb-2 text-lg leading-snug">
                  {post.data.title}
                </h3>
                <p class="text-sm text-gray-500 line-clamp-2 mb-4">{post.data.description}</p>
                <div class="flex items-center justify-between">
                  {post.data.rating && (
                    <div class="flex items-center gap-1">
                      {Array.from({length: 5}).map((_, i) => (
                        <span class={i < post.data.rating! ? 'text-amber-400' : 'text-gray-200'}>★</span>
                      ))}
                    </div>
                  )}
                  {post.data.price && (
                    <span class="text-sm font-semibold text-emerald-600">{post.data.price}</span>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA / Newsletter -->
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="bg-gradient-to-r from-indigo-600 to-indigo-800 rounded-2xl p-8 md:p-12 text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">Never miss a deal</h2>
        <p class="text-indigo-200 mb-6 max-w-md mx-auto">
          Get weekly picks of the best pet tech deals and new product reviews, straight to your inbox.
        </p>
        <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
          <input
            type="email"
            placeholder="you@email.com"
            class="flex-1 px-4 py-3 rounded-lg text-sm border-0 focus:outline-none focus:ring-2 focus:ring-emerald-400"
          />
          <button type="submit" class="px-6 py-3 bg-emerald-500 text-white font-semibold rounded-lg hover:bg-emerald-600 transition-colors text-sm cursor-pointer">
            Subscribe
          </button>
        </form>
        <p class="text-xs text-indigo-300 mt-3">No spam, unsubscribe anytime.</p>
      </div>
    </section>

    <Footer />
  </body>
</html>
