---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`About | ${SITE_TITLE}`} description="About PetTech — who we are and how we review smart pet gadgets." />
  </head>
  <body class="bg-white text-gray-900 font-sans">
    <Header />
    <main class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-6">About PetTech</h1>

      <div class="prose prose-lg max-w-none text-gray-700 space-y-5">
        <p class="text-lg leading-relaxed">
          We're pet owners who got tired of buying smart gadgets that didn't work as advertised. So we started testing them ourselves — rigorously, honestly, and with real pets.
        </p>

        <h2 class="text-2xl font-bold text-gray-900 mt-10">How We Review</h2>
        <p>Every product we review goes through our testing process:</p>
        <ul class="space-y-2 list-disc pl-5">
          <li><strong>Real-world testing</strong> — we use each product for at least 2 weeks with actual pets</li>
          <li><strong>Feature comparison</strong> — we compare specs, app quality, and build</li>
          <li><strong>Value assessment</strong> — we factor in price, durability, and ongoing costs</li>
          <li><strong>Honest ratings</strong> — no paid placements, no inflated scores</li>
        </ul>

        <h2 class="text-2xl font-bold text-gray-900 mt-10">Affiliate Disclosure</h2>
        <p>
          PetTech is reader-supported. When you buy through links on our site, we may earn an affiliate commission. This never influences our reviews or recommendations. We only recommend products we'd use ourselves.
        </p>

        <h2 class="text-2xl font-bold text-gray-900 mt-10">Get in Touch</h2>
        <p>
          Have a product you'd like us to review? Questions about a recommendation? Drop us a line at <strong>hello@pettech.online</strong>.
        </p>
      </div>
    </main>
    <Footer />
  </body>
</html>
