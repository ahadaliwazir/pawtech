---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categories = [...new Set(posts.map(p => p.data.category))];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`All Reviews | ${SITE_TITLE}`} description="In-depth reviews of smart pet tech — GPS trackers, feeders, cameras, and more." />
  </head>
  <body class="bg-white text-gray-900 font-sans">
    <Header />
    <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="mb-10">
        <h1 class="text-3xl md:text-4xl font-extrabold mb-3">All Reviews</h1>
        <p class="text-gray-500 text-lg">Honest, tested reviews of every smart pet gadget we get our hands on.</p>
      </div>

      <!-- Category filter -->
      <div class="flex flex-wrap gap-2 mb-8">
        <span class="px-3 py-1.5 bg-indigo-600 text-white text-xs font-medium rounded-full">All</span>
        {categories.map(cat => (
          <a href={`/categories/${cat}/`} class="px-3 py-1.5 bg-gray-100 text-gray-600 text-xs font-medium rounded-full no-underline hover:bg-gray-200 transition-colors capitalize">
            {cat?.replace(/-/g, ' ')}
          </a>
        ))}
      </div>

      <!-- Posts grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map(post => (
          <a href={`/reviews/${post.id}/`} class="group bg-white rounded-xl overflow-hidden border border-gray-100 hover:shadow-lg transition-all no-underline">
            <div class="p-6">
              {post.data.category && (
                <span class="inline-block px-2 py-0.5 text-xs font-medium text-indigo-700 bg-indigo-50 rounded mb-3 capitalize">
                  {post.data.category.replace(/-/g, ' ')}
                </span>
              )}
              <h2 class="font-semibold text-gray-900 group-hover:text-indigo-600 transition-colors mb-2 text-lg leading-snug">
                {post.data.title}
              </h2>
              <p class="text-sm text-gray-500 line-clamp-2 mb-4">{post.data.description}</p>
              <div class="flex items-center justify-between">
                {post.data.rating && (
                  <div class="flex items-center gap-0.5 text-sm">
                    {Array.from({length: 5}).map((_, i) => (
                      <span class={i < post.data.rating! ? 'text-amber-400' : 'text-gray-200'}>★</span>
                    ))}
                  </div>
                )}
                {post.data.price && (
                  <span class="text-sm font-semibold text-emerald-600">{post.data.price}</span>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    </main>
    <Footer />
  </body>
</html>
