---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';

const categories = [
  { name: 'GPS Trackers', slug: 'gps-trackers', icon: '📍', desc: 'Real-time location tracking for dogs and cats. Never lose your pet again.', count: 'GPS trackers' },
  { name: 'Automatic Feeders', slug: 'feeders', icon: '🍽️', desc: 'Smart feeders that dispense meals on schedule. Perfect for busy pet parents.', count: 'auto feeders' },
  { name: 'Pet Cameras', slug: 'cameras', icon: '📹', desc: 'HD cameras with two-way audio and treat dispensing. Check in from anywhere.', count: 'pet cameras' },
  { name: 'Smart Litter Boxes', slug: 'litter-boxes', icon: '🚿', desc: 'Self-cleaning litter boxes that handle the mess automatically.', count: 'smart litter boxes' },
  { name: 'Wearables', slug: 'wearables', icon: '⌚', desc: 'Activity monitors and health trackers designed for pets.', count: 'pet wearables' },
  { name: 'Smart Pet Doors', slug: 'smart-doors', icon: '🚪', desc: 'Microchip and app-controlled doors for secure pet access.', count: 'smart doors' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Categories | ${SITE_TITLE}`} description="Browse smart pet tech by category — GPS trackers, feeders, cameras, litter boxes, and more." />
  </head>
  <body class="bg-white text-gray-900 font-sans">
    <Header />
    <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="mb-10">
        <h1 class="text-3xl md:text-4xl font-extrabold mb-3">Categories</h1>
        <p class="text-gray-500 text-lg">Browse smart pet gadgets by type</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {categories.map(cat => (
          <a href={`/categories/${cat.slug}/`} class="group p-8 bg-gray-50 rounded-2xl hover:bg-white hover:shadow-xl transition-all no-underline border border-transparent hover:border-gray-200">
            <span class="text-4xl block mb-4">{cat.icon}</span>
            <h2 class="text-xl font-bold text-gray-900 group-hover:text-indigo-600 transition-colors mb-2">{cat.name}</h2>
            <p class="text-sm text-gray-500 leading-relaxed mb-4">{cat.desc}</p>
            <span class="text-indigo-600 text-sm font-medium group-hover:translate-x-1 inline-block transition-transform">
              Browse {cat.count} &rarr;
            </span>
          </a>
        ))}
      </div>
    </main>
    <Footer />
  </body>
</html>
